NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://postgres:password@db.example.supabase.co:5432/postgres?schema=public
DIRECT_URL=postgresql://postgres:password@db.example.supabase.co:5432/postgres
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002
JWT_ACCESS_SECRET=replace-with-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
BCRYPT_ROUNDS=12
PASSWORD_RESET_TOKEN_EXP_MINUTES=30
EMAIL_VERIFICATION_TOKEN_EXP_HOURS=24
COOKIE_SECRET=replace-with-long-random-cookie-secret

PRISMA_LOG_QUERIES=false
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_FIRST_NAME=System
SEED_ADMIN_LAST_NAME=Admin
