generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SONGWRITER   @map("songwriter")
  COMPOSER     @map("composer")
  ARTIST       @map("artist")
  PUBLISHER    @map("publisher")
  RECORD_LABEL @map("record_label")
  ADMIN        @map("admin")
}

enum RegistrationType {
  INDIVIDUAL
  COMPANY
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum CompanyType {
  PUBLISHER
  RECORD_LABEL
  ADMINISTRATION
  OTHER
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum SongStatus {
  SUBMITTED
  PROCESSING
  REGISTERED
}

enum WriterRole {
  SONGWRITER
  COMPOSER
  LYRICIST
  ARRANGER
  ADAPTOR
  OTHER
}

enum RoyaltyType {
  PERFORMANCE
  MECHANICAL
  LYRICS
  SYNCHRONIZATION
  OTHER
}

enum RoyaltyStatus {
  PENDING
  PROCESSED
  DISPUTED
  PAID
}

enum StatementStatus {
  DRAFT
  FINALIZED
  SENT
  PAID
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  ADMIN_ALERT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  LOGIN
  LOGOUT
  EXPORT
}

enum AuditEntityType {
  USER
  COMPANY
  KYC
  COMPOSITION
  WRITER
  LYRICS
  ROYALTY
  STATEMENT
  NOTIFICATION
}

model User {
  id                String           @id @default(uuid()) @db.Uuid
  email             String           @unique
  passwordHash      String
  legalName         String?
  stageName         String?
  firstName         String
  lastName          String
  country           String?
  phone             String?
  dateOfBirth       DateTime?
  spotifyArtistLink String?
  pro               String?
  ipiNumber         String?
  role              Role             @default(ARTIST)
  status            UserStatus       @default(ACTIVE)
  registrationType  RegistrationType @default(INDIVIDUAL)
  companyId         String?          @db.Uuid
  emailVerifiedAt               DateTime?
  emailVerificationTokenHash    String?
  emailVerificationExpiresAt    DateTime?
  passwordResetTokenHash        String?
  passwordResetExpiresAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?

  company             Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  sessions            Session[]
  createdCompositions Composition[] @relation("CompositionOwner")
  kycProfile          KYC?          @relation("UserKycSubject")
  reviewedKycs        KYC[]         @relation("KycReviewer")
  writerProfiles      Writer[]
  statements          Statement[]
  notifications       Notification[]
  auditLogs           AuditLog[]    @relation("AuditActor")

  @@index([companyId])
  @@index([role])
  @@index([status])
  @@index([registrationType])
  @@index([dateOfBirth])
  @@index([ipiNumber])
  @@index([emailVerifiedAt])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([role, status, deletedAt])
  @@map("users")
}

model Company {
  id                 String      @id @default(uuid()) @db.Uuid
  name               String
  legalName          String?
  companyNumber      String?
  address            String?
  director           String?
  email              String?
  phone              String?
  registrationNumber String?
  vatNumber          String?
  website            String?
  taxId              String?
  country            String?
  type               CompanyType @default(OTHER)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  deletedAt          DateTime?

  users         User[]
  kycRecords    KYC[]
  compositions  Composition[]
  statements    Statement[]
  notifications Notification[]
  auditLogs     AuditLog[]

  @@index([name])
  @@index([type])
  @@index([deletedAt])
  @@map("companies")
}

model KYC {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String?   @unique @db.Uuid
  companyId      String?   @db.Uuid
  documentType   String
  documentNumber String?
  country        String?
  status         KycStatus @default(PENDING)
  notes          String?
  submittedAt    DateTime  @default(now())
  reviewedAt     DateTime?
  reviewedById   String?   @db.Uuid
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  user       User?    @relation("UserKycSubject", fields: [userId], references: [id], onDelete: Cascade)
  company    Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reviewedBy User?    @relation("KycReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([status])
  @@index([reviewedById])
  @@index([deletedAt])
  @@index([status, deletedAt])
  @@map("kyc")
}

model Composition {
  id               String     @id @default(uuid()) @db.Uuid
  ownerId          String     @db.Uuid
  companyId        String?    @db.Uuid
  dlrpId           String?    @unique
  released         Boolean    @default(false)
  songTitle        String
  alternativeTitle String?
  artistName       String?
  language         String?
  genre            String?
  spotifyUrl       String?
  appleMusicUrl    String?
  youtubeUrl       String?
  ipiNumber        String?
  iswc             String?    @unique
  isrc             String?
  duration         Int?
  releaseDate      DateTime?
  version          String?
  songStatus       SongStatus @default(SUBMITTED)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  deletedAt        DateTime?

  owner     User                @relation("CompositionOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  company   Company?            @relation(fields: [companyId], references: [id], onDelete: SetNull)
  lyrics    Lyrics?
  writers   CompositionWriter[]
  royalties Royalty[]

  @@index([ownerId])
  @@index([companyId])
  @@index([dlrpId])
  @@index([released])
  @@index([songTitle])
  @@index([alternativeTitle])
  @@index([artistName])
  @@index([spotifyUrl])
  @@index([ipiNumber])
  @@index([iswc])
  @@index([isrc])
  @@index([songStatus])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([ownerId, songStatus, deletedAt])
  @@index([ownerId, deletedAt, updatedAt])
  @@map("compositions")
}

model Writer {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String?    @db.Uuid
  firstName String?
  lastName  String?
  legalName String
  stageName String?
  ipiNumber String?    @unique
  pro       String?
  role      WriterRole @default(SONGWRITER)
  dob       DateTime?
  country   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?

  user         User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  compositions CompositionWriter[]
  royalties    Royalty[]

  @@index([userId])
  @@index([firstName])
  @@index([lastName])
  @@index([legalName])
  @@index([stageName])
  @@index([pro])
  @@index([deletedAt])
  @@map("writers")
}

model Lyrics {
  id            String    @id @default(uuid()) @db.Uuid
  compositionId String    @unique @db.Uuid
  body          String
  language      String?
  version       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  composition Composition @relation(fields: [compositionId], references: [id], onDelete: Cascade)

  @@index([deletedAt])
  @@map("lyrics")
}

model Royalty {
  id              String        @id @default(uuid()) @db.Uuid
  compositionId   String?       @db.Uuid
  writerId        String?       @db.Uuid
  type            RoyaltyType
  status          RoyaltyStatus @default(PENDING)
  sourceDsp       String?
  country         String?
  usageDate       DateTime?
  periodYear      Int
  periodMonth     Int
  amount          Decimal       @db.Decimal(18, 4)
  currency        String        @default("USD")
  sharePercentage Decimal       @db.Decimal(5, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  composition Composition?     @relation(fields: [compositionId], references: [id], onDelete: SetNull)
  writer      Writer?          @relation(fields: [writerId], references: [id], onDelete: SetNull)
  statements  StatementRoyalty[]

  @@index([compositionId])
  @@index([writerId])
  @@index([type])
  @@index([status])
  @@index([periodYear, periodMonth])
  @@index([country])
  @@index([sourceDsp])
  @@index([deletedAt])
  @@index([compositionId, status, deletedAt])
  @@index([status, periodYear, periodMonth, deletedAt])
  @@map("royalties")
}

model Statement {
  id          String          @id @default(uuid()) @db.Uuid
  statementNo String          @unique
  userId      String          @db.Uuid
  companyId   String?         @db.Uuid
  periodStart DateTime
  periodEnd   DateTime
  status      StatementStatus @default(DRAFT)
  totalAmount Decimal         @db.Decimal(18, 4)
  currency    String          @default("USD")
  generatedAt DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  royalties StatementRoyalty[]

  @@index([userId])
  @@index([companyId])
  @@index([status])
  @@index([periodStart, periodEnd])
  @@index([deletedAt])
  @@index([userId, status, deletedAt])
  @@map("statements")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String?          @db.Uuid
  companyId String?          @db.Uuid
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  deletedAt DateTime?

  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
  @@index([isRead])
  @@index([type])
  @@index([deletedAt])
  @@index([userId, isRead, deletedAt])
  @@map("notifications")
}

model AuditLog {
  id         String          @id @default(uuid()) @db.Uuid
  actorId    String?         @db.Uuid
  companyId  String?         @db.Uuid
  action     AuditAction
  entityType AuditEntityType
  entityId   String?
  summary    String?
  changes    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  deletedAt  DateTime?

  actor   User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([companyId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("audit_logs")
}

model CompositionWriter {
  id                  String    @id @default(uuid()) @db.Uuid
  compositionId       String    @db.Uuid
  writerId            String    @db.Uuid
  controlledPublisher String?
  writerShare         Decimal   @db.Decimal(5, 2)
  publisherShare      Decimal?  @db.Decimal(5, 2)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  composition Composition @relation(fields: [compositionId], references: [id], onDelete: Cascade)
  writer      Writer      @relation(fields: [writerId], references: [id], onDelete: Cascade)

  @@unique([compositionId, writerId])
  @@index([writerId])
  @@index([deletedAt])
  @@map("composition_writers")
}

model StatementRoyalty {
  id              String    @id @default(uuid()) @db.Uuid
  statementId     String    @db.Uuid
  royaltyId       String    @db.Uuid
  allocatedAmount Decimal   @db.Decimal(18, 4)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  statement Statement @relation(fields: [statementId], references: [id], onDelete: Cascade)
  royalty   Royalty   @relation(fields: [royaltyId], references: [id], onDelete: Cascade)

  @@unique([statementId, royaltyId])
  @@index([royaltyId])
  @@index([deletedAt])
  @@map("statement_royalties")
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  lastUsedAt       DateTime?
  revokedAt        DateTime?
  compromisedAt    DateTime?
  replacedById     String?   @db.Uuid
  deletedAt        DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([deletedAt])
  @@map("sessions")
}
